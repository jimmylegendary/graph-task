{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph-task.schema.high-level.v2",
  "title": "GraphTaskHighLevelSchema",
  "description": "High-level graph-task entity schema. Structural and operating rules are documented separately in references/rules.graph-task.md.",
  "type": "object",
  "required": ["project"],
  "properties": {
    "project": {
      "$ref": "#/$defs/project"
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["id", "title", "description", "goal", "steps", "stepEdges"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goal": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        },
        "stepEdges": {
          "type": "array",
          "items": { "$ref": "#/$defs/stepEdge" }
        },
        "status": { "type": "string" },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["id", "projectId", "stepType", "description", "phases", "phaseEdges"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "stepType": { "type": "string" },
        "description": { "type": "string" },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/phase" },
          "minItems": 1
        },
        "phaseEdges": {
          "type": "array",
          "items": { "$ref": "#/$defs/phaseEdge" }
        },
        "status": { "type": "string" },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "phase": {
      "type": "object",
      "required": ["id", "stepId", "phaseType", "description", "rootNodeId", "nodes", "edges"],
      "properties": {
        "id": { "type": "string" },
        "stepId": { "type": "string" },
        "phaseType": {
          "type": "string",
          "enum": ["diverge", "converge", "verify", "commit"]
        },
        "description": { "type": "string" },
        "rootNodeId": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" },
          "minItems": 1
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        },
        "status": { "type": "string" },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["id", "phaseId", "nodeType", "title", "description"],
      "properties": {
        "id": { "type": "string" },
        "phaseId": { "type": "string" },
        "nodeType": {
          "type": "string",
          "enum": ["root", "work"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "phaseId", "fromNodeId", "toNodeId", "edgeType"],
      "properties": {
        "id": { "type": "string" },
        "phaseId": { "type": "string" },
        "fromNodeId": { "type": "string" },
        "toNodeId": { "type": "string" },
        "edgeType": {
          "type": "string",
          "enum": ["flow", "dependency"]
        },
        "description": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "stepEdge": {
      "type": "object",
      "required": ["id", "projectId", "fromStepId", "toStepId"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "fromStepId": { "type": "string" },
        "toStepId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "phaseEdge": {
      "type": "object",
      "required": ["id", "stepId", "fromPhaseId", "toPhaseId"],
      "properties": {
        "id": { "type": "string" },
        "stepId": { "type": "string" },
        "fromPhaseId": { "type": "string" },
        "toPhaseId": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
